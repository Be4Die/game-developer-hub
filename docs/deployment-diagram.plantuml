@startuml
!theme plain
' Настройки для строгих прямоугольных линий и отступов, чтобы избежать "каши"
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 70
skinparam componentStyle rectangle

' ==========================================
' 1. КЛИЕНТСКАЯ ЗОНА (Верхний уровень)
' ==========================================
together {
    node "<<device>>\nУстройство пользователя\n(Разработчик)" as dev_device {
        node "<<execution environment>>\nТелеграмм Чат" as dev_tg
        node "<<execution environment>>\nБраузер" as dev_browser {
            artifact "<<artifact>>\nSPA Приложение" as dev_spa
        }
    }

    cloud "<<system>>\nTelegram API\n(Облако)" as tg_cloud

    node "<<device>>\nУстройство пользователя\n(Игрок)" as player_device {
        node "<<execution environment>>\nБраузер " as player_browser {
            node "<<execution environment>>\nВеб игра" as player_game {
                component "<<component>>\nПлагин обнаружения\nсервера" as player_plugin
            }
        }
    }
}

' ==========================================
' 2. ПУБЛИЧНАЯ ЗОНА
' ==========================================
node "<<device>>\nПубличный сервер" as public_server {
    node "<<execution environment>>\nNginx" as nginx {
        component "<<component>>\nОбратный прокси" as reverse_proxy
        component "<<component>>\nСтатический веб-сервер" as static_server
        artifact "<<artifact>>\nSPA Приложение " as hosted_spa
    }
}

' ==========================================
' 3. ВНУТРЕННЯЯ ЗОНА (БЭКЕНД)
' ==========================================
node "<<device>>\nВнутренний сервер" as internal_server {
    
    node "<<execution environment>>\nКонсоль разработчика" as dev_console {
        component "<<component>>\nУправление черновиками" as c_drafts
        component "<<component>>\nВнутренний чат" as c_chat
        component "<<component>>\nСистема модерации" as c_mod
        component "<<component>>\nУправление серверами" as c_servers
        component "<<component>>\nАутентификация" as c_auth
        component "<<component>>\nАналитика и отчеты" as c_analytics
    }

    node "<<execution environment>>\nОркестратор Игровых серверов" as orchestrator {
        component "<<component>>\nВыдача подключений" as o_conn
        component "<<component>>\nОбработка сборок" as o_builds
        component "<<component>>\nУправление инстансами" as o_instances
        artifact "<<artifact>>\nОбраз сервера" as o_image
    }

    node "<<execution environment>>\nТелеграмм бот" as tg_bot {
        component "<<component>>\nУведомления" as tg_notifications
    }
    
    ' Выстраиваем сервисы в один ряд для красоты
    dev_console -[hidden]right- orchestrator
    orchestrator -[hidden]right- tg_bot
}

' ==========================================
' 4. БАЗЫ ДАННЫХ И ИГРОВЫЕ НОДЫ (Нижний уровень)
' ==========================================
together {
    package "Хранилища данных" {
        database "Файловое хранилище" as file_storage
        database "PostgreSQL" as postgres
        database "Redis" as redis
    }

    node "<<device>>\nВыделенный игровой сервер" as game_server_node {
        node "<<execution environment>>\nDocker" as docker {
            node "<<execution environment>>\nСервис вычислительного узла" as node_agent {
                component "<<component>>\nМодуль обнаружения" as a_discovery
                component "<<component>>\nМодуль развертывания" as a_deploy
                component "<<component>>\nDocker API" as a_docker_api
            }
            node "<<execution environment>>\nИгровой сервер" as game_instance
        }
    }
}

' ==========================================
' МАРШРУТИЗАЦИЯ И СВЯЗИ
' ==========================================

' Клиенты -> Прокси (Направляем строго вниз)
dev_spa -down-> reverse_proxy : <<protocol>>\nHTTPS
player_plugin -down-> reverse_proxy : <<protocol>>\nHTTPS

' Путь Telegram
dev_tg -right-> tg_cloud : <<protocol>>\nMTProto
tg_cloud -down-> tg_bot : <<protocol>>\nHTTPS (Webhooks)

' Прокси -> Внутренние сервисы
reverse_proxy -down-> dev_console : HTTP
reverse_proxy -down-> orchestrator : HTTP / gRPC

' Связь внутренних сервисов (gRPC)
dev_console -right-> orchestrator : <<protocol>>\ngRPC

' --- СВЯЗИ С БАЗАМИ ДАННЫХ ---
' (Ведем от самих контейнеров, чтобы не было 100 перекрещивающихся линий от каждого компонента)
dev_console -down-> postgres : <<protocol>>\nSQL
dev_console -down-> redis : <<protocol>>\nRESP / TCP
dev_console -down-> file_storage : <<protocol>>\nS3 API

orchestrator -down-> postgres : <<protocol>>\nSQL
orchestrator -down-> file_storage : <<protocol>>\nS3 API

' --- СВЯЗИ С ИГРОВЫМИ НОДАМИ ---
o_instances -down-> node_agent : <<protocol>>\ngRPC
o_builds -down-> node_agent : <<protocol>>\ngRPC + streaming
o_conn .down.> a_discovery : Получение адреса

' ГЛАВНАЯ ИГРОВАЯ СВЯЗЬ: Игрок -> Сервер напрямую минуя Nginx
player_game ====> game_instance : <<protocol>>\nWebSocket / TCP

@enduml